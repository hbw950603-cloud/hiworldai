{
  "rewrites": [
    { "source": "/tutorials/:path*", "destination": "/tutorials/:path*.html" },
    { "source": "/blog/:path*", "destination": "/blog/:path*.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
